      "version": 507,
      "versionNonce": 879370855,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1774451660691,
      "link": null,
      "locked": false,
      "text": "Added to input dataframe: \n- 30 day precipitation rolling average for model to understand state of environment \n- precipitation surplus to clarify relationship between ETP and precipitation (this can be confusing without a connection) \n- temperature: this was included to create melt indicator, but the model is seeing both. Decided to keep both for now and will evaluate if needed later. \n- binary melt indicator to indicate if melting is occurring   \n ",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Added to input dataframe: \n- 30 day precipitation rolling average for model to understand state of environment \n- precipitation surplus to clarify relationship between ETP and precipitation (this can be confusing without a connection) \n- temperature: this was included to create melt indicator, but the model is seeing both. Decided to keep both for now and will evaluate if needed later. \n- binary melt indicator to indicate if melting is occurring   \n ",
      "autoResize": true,
      "lineHeight": 1.25
    },
