    {
      "id": "ZzILDCg7ZvnuBb-byzhS3",
      "type": "text",
      "x": 4657.367700189303,
      "y": 2729.667908443058,
      "width": 2668.7890625,
      "height": 270,
      "angle": 0,
      "strokeColor": "#1e1e1e",
